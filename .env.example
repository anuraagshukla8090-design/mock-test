# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/questionbank

# ── LLM provider: "groq" | "ollama" | "qwen" ─────────────────────────────────
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

GROQ_API_KEY=
QWEN_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# ── MinerU ────────────────────────────────────────────────────────────────────
# Absolute path to the Python interpreter that has magic-pdf installed.
# There is no safe default for this — it is machine-specific.
# Example (Linux/macOS): /home/user/mocktest/test-ingestion/.venv310/bin/python
# Example (Windows):     C:/Users/<you>/mocktest/test-ingestion/.venv310/Scripts/python.exe
MINERU_PYTHON=

# Absolute path to the single-PDF MinerU runner script.
# Defaults to <project_root>/scripts/run_mineru_single.py — only set this if
# you have moved the script elsewhere.
# MINERU_SCRIPT=

# ── Storage ───────────────────────────────────────────────────────────────────
# Where question images and MinerU outputs are stored.
# Defaults to <project_root>/storage — only set this if you want a different location.
# STORAGE_DIR=/path/to/storage
